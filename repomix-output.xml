    public string? RefreshToken { get; set; }  // สำหรับระบบ Login (JWT)
    public DateTime? RefreshTokenExpiryTime { get; set; }

    // Navigation properties
    public ICollection<UserRole> UserRoles { get; set; } = [];
}
