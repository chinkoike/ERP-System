          <div class="mb-6 text-sm text-slate-500">
            คุณต้องการลบ <strong class="text-slate-900">{{ deleteTarget.name }}</strong> ใช่หรือไม่?
            ไม่สามารถยกเลิกได้
          </div>
          <div class="flex justify-end gap-2">
